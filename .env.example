# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/cs_dept_management

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_access_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM="CS Department GPGC Lakki Marwat" <no-reply@gpgclakki.edu.pk>

# CORS Settings
FRONTEND_URL=http://localhost:5173
